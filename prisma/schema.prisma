generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum AdminRole {
  SUPER_ADMIN
  FINANCE
  SUPPORT
  OPERATIONS
}

enum CustomerType {
  PERSONAL
  COMPANY
  RESELLER
}

enum CustomerStatus {
  ACTIVE
  SUSPENDED
  OVERDUE
  ARCHIVED
}

enum ProductCategory {
  CLOUD_SERVER
  BARE_METAL
  STORAGE
  CDN
  SECURITY
  NETWORK
  LICENSE
  DOMAIN
  OTHER
}

enum ProductStatus {
  ACTIVE
  DRAFT
  DISABLED
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  SEMI_ANNUALLY
  ANNUALLY
  BIENNIALLY
  TRIENNIALLY
  ONETIME
}

enum ProviderType {
  MOFANG_CLOUD
  MANUAL
}

enum ServiceStatus {
  PENDING
  PROVISIONING
  ACTIVE
  SUSPENDED
  OVERDUE
  TERMINATED
  EXPIRED
  FAILED
}

enum OrderStatus {
  PENDING
  PAID
  PROVISIONING
  ACTIVE
  CANCELLED
  REFUNDED
}

enum InvoiceType {
  ORDER
  RENEWAL
  MANUAL
  CREDIT
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIAL
  PAID
  OVERDUE
  VOID
}

enum PaymentMethod {
  BALANCE
  ALIPAY
  WECHAT
  BANK_TRANSFER
  OFFLINE
  PAYPAL
  STRIPE
  OTHER
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum PaymentSignType {
  HEADER_SECRET
  HMAC_SHA256
}

enum RefundStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELED
}

enum CreditTransactionType {
  RECHARGE
  CONSUME
  REFUND
  ADJUSTMENT
  AUTO_RENEW
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  PROCESSING
  WAITING_CUSTOMER
  RESOLVED
  CLOSED
}

enum ProviderSyncStatus {
  SUCCESS
  FAILED
  PENDING
}

enum TaskRunStatus {
  PENDING
  SUCCESS
  FAILED
  SKIPPED
}

enum NotificationChannel {
  SYSTEM
  EMAIL
  SMS
  WEBHOOK
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  CANCELED
}

model AdminUser {
  id                 String              @id @default(cuid())
  name               String
  email              String              @unique
  passwordHash       String
  role               AdminRole           @default(FINANCE)
  isActive           Boolean             @default(true)
  lastLoginAt        DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  auditLogs          AuditLog[]
  creditTransactions CreditTransaction[] @relation("CreditOperator")
  createdNotifications NotificationMessage[] @relation("NotificationCreator")
  processedRefunds   RefundRecord[]      @relation("RefundProcessor")
  tickets            Ticket[]            @relation("TicketAssignee")
}

model Customer {
  id                 String              @id @default(cuid())
  customerNo         String              @unique
  name               String
  companyName        String?
  email              String              @unique
  phone              String?
  contactQQ          String?
  contactWechat      String?
  type               CustomerType        @default(PERSONAL)
  status             CustomerStatus      @default(ACTIVE)
  level              String              @default("standard")
  creditBalance      Int                 @default(0)
  tags               String?
  notes              String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  creditTransactions CreditTransaction[]
  invoices           Invoice[]
  orders             Order[]
  payments           Payment[]
  refunds            RefundRecord[]
  services           ServiceInstance[]
  tickets            Ticket[]
  billingJobs        BillingJob[]
  notifications      NotificationMessage[]
  portalUsers        CustomerUser[]
  contacts           CustomerContact[]
  certification      CustomerCertification?
  followUps          CustomerFollowUp[]

  @@index([status, createdAt])
}

model Product {
  id                String          @id @default(cuid())
  code              String          @unique
  name              String
  category          ProductCategory
  status            ProductStatus   @default(ACTIVE)
  billingCycle      BillingCycle    @default(MONTHLY)
  price             Int
  setupFee          Int             @default(0)
  stock             Int             @default(0)
  autoProvision     Boolean         @default(true)
  providerType      ProviderType    @default(MOFANG_CLOUD)
  providerProductId String?
  regionTemplate    String?
  description       String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  items             OrderItem[]
  plans             CloudPlan[]
  services          ServiceInstance[]

  @@index([status, category])
}

model Order {
  id          String      @id @default(cuid())
  orderNo     String      @unique
  customerId  String
  status      OrderStatus @default(PENDING)
  totalAmount Int
  paidAmount  Int         @default(0)
  currency    String      @default("CNY")
  source      String      @default("admin")
  orderType   String      @default("new")
  dueDate     DateTime?
  paidAt      DateTime?
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  customer    Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  invoices    Invoice[]
  items       OrderItem[]
  payments    Payment[]
  services    ServiceInstance[]

  @@index([status, createdAt])
  @@index([customerId, createdAt])
}

model OrderItem {
  id             String           @id @default(cuid())
  orderId        String
  productId      String
  planId         String?
  serviceId      String?
  title          String
  quantity       Int              @default(1)
  unitPrice      Int
  cycle          BillingCycle
  totalAmount    Int
  configSnapshot String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  order          Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product        Product          @relation(fields: [productId], references: [id])
  plan           CloudPlan?       @relation(fields: [planId], references: [id], onDelete: SetNull)
  service        ServiceInstance? @relation(fields: [serviceId], references: [id])

  @@index([orderId])
}

model ServiceInstance {
  id                 String         @id @default(cuid())
  serviceNo          String         @unique
  customerId         String
  productId          String
  planId             String?
  orderId            String?
  vpcNetworkId       String?
  name               String
  hostname           String?
  providerType       ProviderType   @default(MOFANG_CLOUD)
  providerResourceId String?
  region             String?
  billingCycle       BillingCycle   @default(MONTHLY)
  status             ServiceStatus  @default(PROVISIONING)
  ipAddress          String?
  cpuCores           Int?
  memoryGb           Int?
  storageGb          Int?
  monthlyCost        Int            @default(0)
  nextDueDate        DateTime?
  activatedAt        DateTime?
  expiresAt          DateTime?
  configSnapshot     String?
  lastSyncAt         DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  customer           Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  order              Order?         @relation(fields: [orderId], references: [id], onDelete: SetNull)
  plan               CloudPlan?     @relation(fields: [planId], references: [id], onDelete: SetNull)
  product            Product        @relation(fields: [productId], references: [id])
  vpcNetwork         ServiceVpcNetwork? @relation(fields: [vpcNetworkId], references: [id], onDelete: SetNull)
  backups            ServiceBackup[]
  billingJobs        BillingJob[]
  disks              ServiceDisk[]
  invoices           Invoice[]
  ipAddresses        ServiceIpAddress[]
  items              OrderItem[]
  securityGroups     ServiceSecurityGroup[]
  snapshots          ServiceSnapshot[]
  tickets            Ticket[]

  @@index([status, nextDueDate])
  @@index([providerType, providerResourceId])
}

model CustomerUser {
  id           String   @id @default(cuid())
  customerId   String
  name         String
  email        String   @unique
  phone        String?
  passwordHash String
  role         String   @default("OWNER")
  isOwner      Boolean  @default(false)
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, isActive])
}

model CustomerContact {
  id         String   @id @default(cuid())
  customerId String
  name       String
  department String?
  role       String?
  email      String?
  phone      String?
  isPrimary  Boolean  @default(false)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, createdAt])
}

model CustomerCertification {
  id                String   @id @default(cuid())
  customerId        String   @unique
  subjectType       String   @default("PERSONAL")
  subjectName       String
  idNumber          String?
  businessLicenseNo String?
  status            String   @default("PENDING")
  submittedAt       DateTime @default(now())
  verifiedAt        DateTime?
  reviewNote        String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  customer          Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model CustomerFollowUp {
  id           String   @id @default(cuid())
  customerId   String
  type         String   @default("NOTE")
  title        String
  content      String
  nextFollowAt DateTime?
  operatorId   String?
  operatorName String
  operatorRole String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, createdAt])
}

model CloudRegion {
  id               String       @id @default(cuid())
  code             String       @unique
  name             String
  location         String?
  providerType     ProviderType @default(MOFANG_CLOUD)
  providerRegionId String?
  description      String?
  isActive         Boolean      @default(true)
  sortOrder        Int          @default(0)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  images           CloudImage[]
  plans            CloudPlan[]
  zones            CloudZone[]

  @@index([isActive, sortOrder])
}

model CloudZone {
  id             String      @id @default(cuid())
  regionId       String
  code           String      @unique
  name           String
  providerZoneId String?
  isActive       Boolean     @default(true)
  sortOrder      Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  plans          CloudPlan[]
  region         CloudRegion @relation(fields: [regionId], references: [id], onDelete: Cascade)

  @@index([regionId, isActive, sortOrder])
}

model CloudFlavor {
  id             String          @id @default(cuid())
  code           String          @unique
  name           String
  category       ProductCategory @default(CLOUD_SERVER)
  cpu            Int
  memoryGb       Int
  storageGb      Int?
  bandwidthMbps  Int?
  gpuCount       Int             @default(0)
  description    String?
  isActive       Boolean         @default(true)
  sortOrder      Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  plans          CloudPlan[]

  @@index([category, isActive, sortOrder])
}

model CloudImage {
  id           String       @id @default(cuid())
  code         String       @unique
  name         String
  osType       String
  version      String?
  architecture String       @default("x86_64")
  regionId     String?
  description  String?
  isPublic     Boolean      @default(true)
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  plans        CloudPlan[]
  region       CloudRegion? @relation(fields: [regionId], references: [id], onDelete: SetNull)

  @@index([isActive, isPublic])
}

model CloudPlan {
  id           String       @id @default(cuid())
  code         String       @unique
  name         String
  productId    String
  regionId     String
  zoneId       String?
  flavorId     String?
  imageId      String?
  billingCycle BillingCycle @default(MONTHLY)
  salePrice    Int
  marketPrice  Int?
  setupFee     Int          @default(0)
  stock        Int          @default(0)
  isPublic     Boolean      @default(true)
  isActive     Boolean      @default(true)
  configOptions String?
  description  String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  flavor       CloudFlavor? @relation(fields: [flavorId], references: [id], onDelete: SetNull)
  image        CloudImage?  @relation(fields: [imageId], references: [id], onDelete: SetNull)
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  region       CloudRegion  @relation(fields: [regionId], references: [id], onDelete: Cascade)
  zone         CloudZone?   @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  orderItems   OrderItem[]
  services     ServiceInstance[]

  @@index([productId, isActive, isPublic])
  @@index([regionId, zoneId])
}

model Invoice {
  id          String           @id @default(cuid())
  invoiceNo   String           @unique
  customerId  String
  orderId     String?
  serviceId   String?
  type        InvoiceType      @default(ORDER)
  status      InvoiceStatus    @default(ISSUED)
  subtotal    Int
  taxRate     Int              @default(0)
  taxAmount   Int              @default(0)
  taxProfileCode String?
  taxProfileName String?
  totalAmount Int
  paidAmount  Int              @default(0)
  dueDate     DateTime
  issuedAt    DateTime?
  paidAt      DateTime?
  remark      String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  billingJobs BillingJob[]
  customer    Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  order       Order?           @relation(fields: [orderId], references: [id], onDelete: SetNull)
  refunds     RefundRecord[]
  service     ServiceInstance? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  payments    Payment[]

  @@index([status, dueDate])
  @@index([customerId, createdAt])
}

model Payment {
  id             String        @id @default(cuid())
  paymentNo      String        @unique
  customerId     String
  invoiceId      String?
  orderId        String?
  method         PaymentMethod
  status         PaymentStatus @default(SUCCESS)
  amount         Int
  feeAmount      Int           @default(0)
  transactionNo  String?
  channelPayload String?
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  callbackLogs   PaymentCallbackLog[]
  customer       Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  invoice        Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  order          Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)
  refunds        RefundRecord[]

  @@index([status, paidAt])
  @@index([customerId, createdAt])
}

model Ticket {
  id           String           @id @default(cuid())
  ticketNo     String           @unique
  customerId   String
  serviceId    String?
  assignedToId String?
  subject      String
  priority     TicketPriority   @default(NORMAL)
  status       TicketStatus     @default(OPEN)
  summary      String?
  lastReplyAt  DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  assignedTo   AdminUser?       @relation("TicketAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  customer     Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  replies      TicketReply[]
  service      ServiceInstance? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([status, priority, createdAt])
}

model TicketReply {
  id         String   @id @default(cuid())
  ticketId   String
  authorType String
  authorName String
  content    String
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
}

model PaymentCallbackLog {
  id            String        @id @default(cuid())
  paymentId     String?
  method        PaymentMethod?
  invoiceNo     String?
  paymentNo     String?
  transactionNo String?
  callbackStatus String?
  signature     String?
  payload       String?
  message       String?
  isHandled     Boolean       @default(false)
  handledAt     DateTime?
  createdAt     DateTime      @default(now())
  payment       Payment?      @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([transactionNo])
}

model ProviderSyncLog {
  id           String             @id @default(cuid())
  providerType ProviderType       @default(MOFANG_CLOUD)
  action       String
  resourceType String
  resourceId   String?
  status       ProviderSyncStatus @default(PENDING)
  message      String?
  requestBody  String?
  responseBody String?
  syncedAt     DateTime           @default(now())

  @@index([providerType, syncedAt])
}

model BillingSetting {
  id                  String   @id @default("default")
  invoiceLeadDays     Int      @default(7)
  graceDays           Int      @default(3)
  autoSuspendDays     Int      @default(7)
  autoTerminateDays   Int      @default(30)
  autoRenewByBalance  Boolean  @default(true)
  allowNegativeBalance Boolean @default(false)
  invoicePrefix       String   @default("INV")
  invoiceIssuerName   String   @default("IDC云业务管理系统")
  invoiceTaxNo        String?
  financeEmail        String?
  defaultTaxRate      Int      @default(13)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model InvoiceTaxProfile {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  taxRate     Int      @default(13)
  description String?
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, isDefault, createdAt])
}

model PaymentGatewayConfig {
  id             String          @id @default(cuid())
  method         PaymentMethod   @unique
  name           String
  merchantId     String?
  appId          String?
  apiBaseUrl     String?
  signType       PaymentSignType @default(HEADER_SECRET)
  callbackSecret String
  callbackHeader String?
  notifyUrl      String?
  returnUrl      String?
  isEnabled      Boolean         @default(true)
  remark         String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([isEnabled, createdAt])
}

model CreditTransaction {
  id            String                @id @default(cuid())
  customerId    String
  operatorId    String?
  type          CreditTransactionType
  amount        Int
  balanceAfter  Int
  description   String
  createdAt     DateTime              @default(now())
  customer      Customer              @relation(fields: [customerId], references: [id], onDelete: Cascade)
  operator      AdminUser?            @relation("CreditOperator", fields: [operatorId], references: [id], onDelete: SetNull)

  @@index([customerId, createdAt])
}

model BillingJob {
  id          String        @id @default(cuid())
  jobType     String
  status      TaskRunStatus @default(PENDING)
  customerId  String?
  serviceId   String?
  invoiceId   String?
  message     String?
  payload     String?
  executedAt  DateTime      @default(now())
  createdAt   DateTime      @default(now())
  customer    Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  invoice     Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  service     ServiceInstance? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([jobType, executedAt])
  @@index([status, executedAt])
}

model AsyncTaskJob {
  id           String        @id @default(cuid())
  queueName    String
  jobType      String
  module       String
  status       TaskRunStatus @default(PENDING)
  targetType   String?
  targetId     String?
  notificationId String?
  payload      String?
  result       String?
  errorMessage String?
  attempts     Int           @default(0)
  availableAt  DateTime      @default(now())
  executedAt   DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  notification NotificationMessage? @relation("TaskNotification", fields: [notificationId], references: [id], onDelete: SetNull)

  @@index([queueName, status, availableAt])
  @@index([module, createdAt])
}

model AuditLog {
  id          String    @id @default(cuid())
  adminUserId String?
  module      String
  action      String
  targetType  String
  targetId    String?
  summary     String
  detail      String?
  createdAt   DateTime  @default(now())
  adminUser   AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([module, createdAt])
  @@index([targetType, targetId])
}

model RefundRecord {
  id            String       @id @default(cuid())
  refundNo      String       @unique
  paymentId     String
  invoiceId     String?
  customerId    String
  processedById String?
  amount        Int
  method        PaymentMethod
  status        RefundStatus @default(SUCCESS)
  reason        String
  transactionNo String?
  payload       String?
  processedAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  customer      Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  invoice       Invoice?     @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  payment       Payment      @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  processedBy   AdminUser?   @relation("RefundProcessor", fields: [processedById], references: [id], onDelete: SetNull)

  @@index([customerId, createdAt])
  @@index([paymentId, createdAt])
}

model NotificationTemplate {
  id         String              @id @default(cuid())
  code       String              @unique
  name       String
  channel    NotificationChannel @default(SYSTEM)
  subject    String?
  content    String
  variables  String?
  isActive   Boolean             @default(true)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  messages   NotificationMessage[]

  @@index([channel, isActive])
}

model NotificationMessage {
  id            String               @id @default(cuid())
  templateId    String?
  customerId    String?
  createdById   String?
  channel       NotificationChannel  @default(SYSTEM)
  priority      NotificationPriority @default(NORMAL)
  status        NotificationStatus   @default(PENDING)
  recipient     String
  recipientName String?
  subject       String?
  content       String
  module        String?
  relatedType   String?
  relatedId     String?
  payload       String?
  errorMessage  String?
  sentAt        DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  template      NotificationTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  customer      Customer?            @relation(fields: [customerId], references: [id], onDelete: SetNull)
  createdBy     AdminUser?           @relation("NotificationCreator", fields: [createdById], references: [id], onDelete: SetNull)
  tasks         AsyncTaskJob[]       @relation("TaskNotification")

  @@index([customerId, createdAt])
  @@index([status, createdAt])
  @@index([module, createdAt])
}

model ServiceVpcNetwork {
  id            String             @id @default(cuid())
  name          String
  region        String?
  cidr          String
  gateway       String?
  providerVpcId String?
  status        String             @default("ACTIVE")
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  securityGroups ServiceSecurityGroup[]
  services      ServiceInstance[]

  @@index([region, status])
}

model ServiceIpAddress {
  id            String   @id @default(cuid())
  serviceId     String
  address       String
  version       String   @default("IPv4")
  type          String   @default("primary")
  bandwidthMbps Int?
  providerIpId  String?
  isPrimary     Boolean  @default(false)
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  service       ServiceInstance @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId, createdAt])
}

model ServiceDisk {
  id             String   @id @default(cuid())
  serviceId      String
  name           String
  type           String
  sizeGb         Int
  mountPoint     String?
  providerDiskId String?
  isSystem       Boolean  @default(false)
  status         String   @default("ATTACHED")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  service        ServiceInstance @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  snapshots      ServiceSnapshot[]

  @@index([serviceId, createdAt])
}

model ServiceSnapshot {
  id                 String   @id @default(cuid())
  serviceId          String
  sourceDiskId       String?
  name               String
  providerSnapshotId String?
  sizeGb             Int?
  status             String   @default("READY")
  createdAt          DateTime @default(now())
  service            ServiceInstance @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  sourceDisk         ServiceDisk? @relation(fields: [sourceDiskId], references: [id], onDelete: SetNull)

  @@index([serviceId, createdAt])
}

model ServiceBackup {
  id               String   @id @default(cuid())
  serviceId        String
  name             String
  providerBackupId String?
  sizeGb           Int?
  status           String   @default("READY")
  expiresAt        DateTime?
  createdAt        DateTime @default(now())
  service          ServiceInstance @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId, createdAt])
}

model ServiceSecurityGroup {
  id                      String   @id @default(cuid())
  serviceId               String?
  vpcNetworkId            String?
  name                    String
  providerSecurityGroupId String?
  status                  String   @default("ACTIVE")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  rules                   ServiceSecurityGroupRule[]
  service                 ServiceInstance? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  vpcNetwork              ServiceVpcNetwork? @relation(fields: [vpcNetworkId], references: [id], onDelete: SetNull)

  @@index([serviceId, createdAt])
}

model ServiceSecurityGroupRule {
  id              String   @id @default(cuid())
  securityGroupId String
  direction       String
  protocol        String
  portRange       String
  sourceCidr      String
  action          String   @default("ALLOW")
  description     String?
  createdAt       DateTime @default(now())
  securityGroup   ServiceSecurityGroup @relation(fields: [securityGroupId], references: [id], onDelete: Cascade)

  @@index([securityGroupId, createdAt])
}

# 无穷云 IDC 系统本地环境模板
# 使用方式：
# 1. 复制本文件为 .env.local
# 2. 只在 .env.local 中填写真实账号、密码、地址
# 3. .env.local 不要提交到 git

# 应用基础配置
APP_NAME=wuqiongyun-idc-api
HTTP_ADDR=:18080
GIN_MODE=debug

# 存储模式
# memory: 直接使用内存演示数据，适合快速预览界面
# mysql: 连接本地 MySQL，适合联调持久化、报表、Provider 同步链路
STORAGE_DRIVER=memory
STORAGE_STRICT=false
MYSQL_DSN=idc_finance:change-me@tcp(127.0.0.1:3306)/idc_finance?parseTime=true&charset=utf8mb4

# 魔方云 Provider 对接
# 不需要联调时可以留空
MOFANG_CLOUD_BASE_URL=
MOFANG_CLOUD_USERNAME=
MOFANG_CLOUD_PASSWORD=
MOFANG_CLOUD_LANG=zh-cn
MOFANG_CLOUD_INSECURE_SKIP_VERIFY=true
MOFANG_CLOUD_LIST_PATH=/v1/clouds?page=1&per_page=100&sort=desc&orderby=id
MOFANG_CLOUD_INSTANCE_DETAIL_PATH=/v1/clouds/:id

# 上游财务对接
# 当前未对接时可以留空
FINANCE_UPSTREAM_BASE_URL=
FINANCE_UPSTREAM_USERNAME=
FINANCE_UPSTREAM_PASSWORD=
FINANCE_UPSTREAM_SOURCE_NAME=上游财务
FINANCE_UPSTREAM_INSECURE_SKIP_VERIFY=true
